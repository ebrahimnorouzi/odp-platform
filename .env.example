# ─── ODP Evaluation Platform — Environment Variables ───────────
# Copy this to .env and edit before running: cp .env.example .env

# Admin login password (change before deployment!)
ADMIN_PASSWORD=admin123

# JWT signing secret (use a long random string in production)
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret-string

# Public base URL used to build evaluator links
# For local:      http://localhost:8080
# For production: https://your-domain.com
BASE_URL=http://localhost:8080

# Port to expose (nginx listens here)
PORT=8080

# JWT token expiry in hours (default 24)
TOKEN_EXPIRE_HOURS=24
